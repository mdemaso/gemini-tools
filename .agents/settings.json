{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".agents/hooks/sync-and-link.sh .agents"
          }
        ]
      }
    ],
    "BeforeModel": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".gemini/hooks/security-scan.sh"
          }
        ]
      }
    ]
  }
}
